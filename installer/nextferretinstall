        for t in ["debootstrap", "mkfs.btrfs", "parted", "cryptsetup", "wipefs", "mkfs.vfat", "wget", "btrfs"]:
            if not shutil.which(t):
                QMessageBox.critical(None, "Error", f"Missing tool: {t}")
                sys.exit(1)
            
    gui = InstallerGUI()
    gui.apply_styles()
    gui.show()
    sys.exit(app.exec())
