class TUI:
    def __init__(self):
        self.lang = "en"
        
    def _run(self, args):
        cmd = ['whiptail', '--title', TEXT[self.lang]['title'], '--backtitle', "NextFerretOS Installer"] + args
        p = subprocess.run(cmd, stderr=subprocess.PIPE, text=True)
        return p.returncode == 0, p.stderr.strip()

    def msg(self, text):
        self._run(['--msgbox', text, '10', '60'])

    def yesno(self, text):
        r, _ = self._run(['--yesno', text, '10', '60'])
        return r

    def input(self, text, default=""):
        r, val = self._run(['--inputbox', text, '10', '60', default])
        return val if r else None

    def password(self, text):
        r, val = self._run(['--passwordbox', text, '10', '60'])
        return val if r else None

    def menu(self, text, items, height='18'):
        flat_items = []
        for tag, desc in items:
            flat_items.extend([tag, desc])
        r, val = self._run(['--menu', text, height, '70', '10'] + flat_items)
        return val if r else None

    def radiolist(self, text, items):
        flat = []
        for tag, desc, status in items:
            flat.extend([tag, desc, status])
        r, val = self._run(['--radiolist', text, '15', '70', '10'] + flat)
        return val if r else None
        
    def gauge(self, text):
        p = subprocess.Popen(['whiptail', '--title', TEXT[self.lang]['title'], '--gauge', text, '6', '60', '0'], stdin=subprocess.PIPE, text=True)
        return p

class Sys:
    @staticmethod
    def run(cmd, input_text=None, check=True):
        try:
            r = subprocess.run(cmd, shell=True, check=check, text=True, input=input_text, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
            return r.stdout.strip()
        except Exception as e:
            # print(f"DEBUG: Cmd failed {cmd}: {e}") # Uncomment for debug
            return None

    @staticmethod
    def is_online():
        try:
            subprocess.check_call(["ping", "-c", "1", "8.8.8.8"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return True
        except: return False

    @staticmethod
    def get_disks():
        try:
            o = Sys.run("lsblk -d -n -o NAME,SIZE,MODEL,TYPE -J", check=False)
            if not o: return []
            data = json.loads(o)
            return [(d['name'], f"{d['size']} - {d.get('model','')}") for d in data['blockdevices'] if d['type'] == 'disk']
        except: return []

    @staticmethod
    def get_locales():
        locales = []
        fpath = '/usr/share/i18n/SUPPORTED'
        if os.path.exists(fpath):
            with open(fpath, 'r') as f:
                for line in f:
                    parts = line.split()
                    if len(parts) > 0 and 'UTF-8' in line:
                        locales.append((parts[0], ""))
        if not locales:
            raw = Sys.run("locale -a")
            if raw:
                for l in raw.split('\n'):
                    locales.append((l, ""))
        return sorted(locales, key=lambda x: x[0])

    @staticmethod
    def get_timezones():
        zones = []
        base = '/usr/share/zoneinfo'
        if os.path.exists(base):
            for root, dirs, files in os.walk(base):
                for f in files:
                    if f in ['posixrules', 'localtime']: continue
                    full = os.path.join(root, f)
                    rel = os.path.relpath(full, base)
                    if rel.startswith(('posix/', 'right/', 'Etc/')): continue
                    zones.append((rel, ""))
        return sorted(zones, key=lambda x: x[0])

class Installer:
    def __init__(self):
        self.ui = TUI()
        self.conf = {
            "disk": None, "hostname": "nextferret", "user": "ferret", "pass": None,
            "luks": False, "luks_pass": None, "locale": "en_US.UTF-8",
            "timezone": "UTC", "keymap": "us", "de_pkgs": "", "de_name": "None"
        }
        self.mount = "/mnt/nextferret"

    def t(self, k): return TEXT[self.ui.lang].get(k, k)

    def check_reqs(self):
        if os.geteuid() != 0: print("Root required"); sys.exit(1)
        reqs = ["whiptail", "debootstrap", "mkfs.btrfs", "parted", "cryptsetup", "wipefs", "nmcli"]
        for r in reqs:
            if not shutil.which(r): print(f"Missing: {r}"); sys.exit(1)

    def lang_select(self):
        l = self.ui.menu("Language / Idioma", [("en", "English"), ("pt", "Português")])
        if l: 
            self.ui.lang = l
            if l == "pt":
                self.conf.update({"locale": "pt_BR.UTF-8", "timezone": "America/Sao_Paulo", "keymap": "br"})

    def net_menu(self):
        while True:
            status = self.t("net_con") if Sys.is_online() else self.t("net_dis")
            opt = self.ui.menu(self.t("net_stat").format(status), [
                ("WIFI", "Connect to Wi-Fi"),
                ("ETH", "Check Ethernet"),
                ("TEST", "Ping Test"),
                ("BACK", self.t("cancel"))
            ])
            if opt == "BACK" or not opt: break
            
            if opt == "WIFI":
                self.ui.msg(self.t("net_scan"))
                raw = Sys.run("nmcli -t -f SSID,SIGNAL dev wifi list")
                if raw:
                    lines = raw.split('\n')
                    networks = []
                    seen = set()
                    for line in lines:
                        parts = line.split(':')
                        if len(parts) >= 2:
                            ssid = parts[0]
                            if ssid and ssid not in seen:
                                seen.add(ssid)
                                networks.append((ssid, f"Signal: {parts[1]}%"))
                    
                    if networks:
                        sel = self.ui.menu(self.t("net_sel"), networks)
                        if sel:
                            pwd = self.ui.password(self.t("net_pass"))
                            if pwd:
                                Sys.run(f"nmcli dev wifi connect '{sel}' password '{pwd}'", check=False)
                    
            if opt == "ETH":
                Sys.run("nmcli dev connect eth0", check=False) 
                
            if opt == "TEST":
                if Sys.is_online(): self.ui.msg(self.t("net_ok"))
                else: self.ui.msg(self.t("net_fail"))

    def disk_menu(self):
        disks = Sys.get_disks()
        if not disks: 
            self.ui.msg("No disks found!")
            return
        opts = [(f"/dev/{n}", d) for n, d in disks]
        d = self.ui.menu(self.t("disk_sel"), opts)
        if d:
            if self.ui.yesno(self.t("disk_warn").format(d)):
                self.conf["disk"] = d
                if self.ui.yesno(self.t("luks_ask")):
                    p1 = self.ui.password(self.t("luks_pass"))
                    p2 = self.ui.password(self.t("user_pc"))
                    if p1 == p2 and p1:
                        self.conf["luks"] = True
                        self.conf["luks_pass"] = p1
                    else:
                        self.ui.msg(self.t("err_match"))
                        self.conf["luks"] = False
                else:
                    self.conf["luks"] = False

    def user_menu(self):
        self.conf["user"] = self.ui.input(self.t("user_u"), self.conf["user"])
        p1 = self.ui.password(self.t("user_p"))
        p2 = self.ui.password(self.t("user_pc"))
        if p1 == p2 and p1:
            self.conf["pass"] = p1
        else:
            self.ui.msg(self.t("err_match"))

    def loc_menu(self):
        loc_list = Sys.get_locales()
        if loc_list:
            l = self.ui.menu(self.t("loc_sel"), loc_list, height='40')
            if l: self.conf["locale"] = l
        else:
            self.conf["locale"] = self.ui.input("Locale", self.conf["locale"])

        tz_list = Sys.get_timezones()
        if tz_list:
            t = self.ui.menu(self.t("tz_sel"), tz_list, height='40')
            if t: self.conf["timezone"] = t
        else:
            self.conf["timezone"] = self.ui.input("Timezone", self.conf["timezone"])

        k = self.ui.menu(self.t("loc_k"), [("us", "US"), ("br", "BR (ABNT2)"), ("pt", "PT (Portugal)")])
        if k: self.conf["keymap"] = k

    def de_menu(self):
        opts = [
            ("NONE", "CLI Only", "ON"),
            ("XFCE", "XFCE4 (Lightweight)", "OFF"),
            ("GNOME", "GNOME (Modern)", "OFF"),
            ("KDE", "KDE Plasma", "OFF")
        ]
        sel = self.ui.radiolist(self.t("m_de"), opts)
        if sel:
            self.conf["de_name"] = sel
            pkgs = {
                "NONE": "",
                "XFCE": "xfce4 xfce4-goodies lightdm network-manager-gnome",
                "GNOME": "gnome-core gdm3 network-manager-gnome",
                "KDE": "kde-standard sddm"
            }
            self.conf["de_pkgs"] = pkgs.get(sel, "")

    def install(self):
        if not self.conf["disk"] or not self.conf["pass"]: 
            self.ui.msg("Missing Disk or Password.")
            return
        if not self.ui.yesno(self.t("inst_confirm").format(self.conf["disk"])): return

        d = self.conf["disk"]
        mapper = "cryptferret"
        
        gauge = self.ui.gauge(self.t("inst_step"))

        def update(pct):
            try:
                gauge.stdin.write(f"{pct}\n")
                gauge.stdin.flush()
            except: pass

        try:
            update(5)
            Sys.run(f"wipefs -a {d}")
            Sys.run(f"parted -s {d} mklabel gpt")
            Sys.run(f"parted -s {d} mkpart ESP fat32 1MiB 513MiB")
            Sys.run(f"parted -s {d} set 1 esp on")
            Sys.run(f"parted -s {d} mkpart primary 513MiB 100%")
            
            # Wait for kernel to register partitions
            time.sleep(2)

            sep = "p" if "nvme" in d else ""
            p1, p2 = f"{d}{sep}1", f"{d}{sep}2"
            
            # Ensure partitions exist
            if not os.path.exists(p2):
                p1, p2 = f"{d}1", f"{d}2" # Fallback logic

            root_dev = p2

            update(15)
            if self.conf["luks"]:
                Sys.run(f"cryptsetup luksFormat --type luks2 {p2} -", input_text=self.conf["luks_pass"])
                Sys.run(f"cryptsetup open {p2} {mapper} -", input_text=self.conf["luks_pass"])
                root_dev = f"/dev/mapper/{mapper}"

            update(25)
            Sys.run(f"mkfs.vfat -F32 {p1}")
            Sys.run(f"mkfs.btrfs -f -L root {root_dev}")

            os.makedirs("/tmp/inst", exist_ok=True)
            Sys.run(f"mount {root_dev} /tmp/inst")
            Sys.run(f"btrfs sub create /tmp/inst/@")
            Sys.run(f"btrfs sub create /tmp/inst/@home")
            Sys.run(f"umount /tmp/inst")

            os.makedirs(self.mount, exist_ok=True)
            mnt_opts = "defaults,compress=zstd:1,noatime"
            Sys.run(f"mount -o {mnt_opts},subvol=@ {root_dev} {self.mount}")
            os.makedirs(f"{self.mount}/home", exist_ok=True)
            os.makedirs(f"{self.mount}/boot/efi", exist_ok=True)
            Sys.run(f"mount -o {mnt_opts},subvol=@home {root_dev} {self.mount}/home")
            Sys.run(f"mount {p1} {self.mount}/boot/efi")

            update(40)
            
            Sys.run(f"debootstrap --arch=amd64 trixie {self.mount} http://deb.debian.org/debian")

            update(70)
            # IMPORTANT: Mount dev/proc/sys AND efivars for Grub
            for m in ["/dev", "/dev/pts", "/proc", "/sys", "/sys/firmware/efi/efivars"]:
                if os.path.exists(m):
                    Sys.run(f"mount --bind {m} {self.mount}{m}")
            
            shutil.copy("/etc/resolv.conf", f"{self.mount}/etc/resolv.conf")
            
            uuid_root = Sys.run(f"blkid -s UUID -o value {root_dev}")
            uuid_efi = Sys.run(f"blkid -s UUID -o value {p1}")
            
            with open(f"{self.mount}/etc/fstab", "w") as f:
                f.write(f"UUID={uuid_root} / btrfs {mnt_opts},subvol=@ 0 0\n")
                f.write(f"UUID={uuid_root} /home btrfs {mnt_opts},subvol=@home 0 0\n")
                f.write(f"UUID={uuid_efi} /boot/efi vfat umask=0077 0 2\n")

            crypt_entry = ""
            pkgs_extra = ""
            if self.conf["luks"]:
                u_luks = Sys.run(f"blkid -s UUID -o value {p2}")
                # Use echo to create crypttab safely
                crypt_entry = f"echo '{mapper} UUID={u_luks} none luks,discard,initramfs' > /etc/crypttab"
                pkgs_extra = "cryptsetup-initramfs"

            script = f"""#!/bin/bash
export DEBIAN_FRONTEND=noninteractive
apt-get update
apt-get install -y linux-image-amd64 sudo network-manager firmware-linux grub-efi-amd64-signed shim-signed locales keyboard-configuration console-setup {self.conf['de_pkgs']} {pkgs_extra}
sed -i "s/^# *{self.conf['locale']}/{self.conf['locale']}/" /etc/locale.gen
locale-gen
echo "LANG={self.conf['locale']}" > /etc/default/locale
echo 'XKBLAYOUT="{self.conf['keymap']}"' > /etc/default/keyboard
dpkg-reconfigure -f noninteractive keyboard-configuration
ln -sf /usr/share/zoneinfo/{self.conf['timezone']} /etc/localtime
{crypt_entry}
useradd -m -s /bin/bash -G sudo {self.conf['user']}
echo "{self.conf['user']}:{self.conf['pass']}" | chpasswd
echo "root:{self.conf['pass']}" | chpasswd
echo "{self.conf['hostname']}" > /etc/hostname
grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=NextFerretOS --recheck
sed -i 's/GRUB_CMDLINE_LINUX_DEFAULT=""/GRUB_CMDLINE_LINUX_DEFAULT="quiet splash"/' /etc/default/grub
update-grub
systemctl enable NetworkManager
exit 0
"""
            with open(f"{self.mount}/setup.sh", "w") as f: f.write(script)
            Sys.run(f"chmod +x {self.mount}/setup.sh")
            Sys.run(f"chroot {self.mount} /setup.sh")

            update(90)
            # Unmount safely
            time.sleep(2)
            Sys.run(f"umount -R {self.mount}", check=False)
            if self.conf["luks"]: Sys.run(f"cryptsetup close {mapper}", check=False)
            
            update(100)
            time.sleep(1)
            gauge.stdin.close()
            gauge.wait()

            if self.ui.yesno(self.t("inst_done")):
                Sys.run("reboot")
        except Exception as e:
            self.ui.msg(f"Fatal Error: {str(e)}")
            gauge.terminate()

    def main(self):
        self.check_reqs()
        self.lang_select()
        while True:
            m = [
                ("NET", self.t("m_net")),
                ("DISK", f"{self.t('m_disk')} [{self.conf['disk'] or 'None'}]"),
                ("USER", self.t("m_user")),
                ("LOC", self.t("m_loc")),
                ("DE", f"{self.t('m_de')} [{self.conf['de_name']}]"),
                ("INSTALL", self.t("m_inst")),
                ("EXIT", self.t("m_exit"))
            ]
            sel = self.ui.menu(self.t("menu_main"), m)
            if sel == "NET": self.net_menu()
            elif sel == "DISK": self.disk_menu()
            elif sel == "USER": self.user_menu()
            elif sel == "LOC": self.loc_menu()
            elif sel == "DE": self.de_menu()
            elif sel == "INSTALL": self.install()
            elif sel == "EXIT" or sel is None: sys.exit(0)

if __name__ == "__main__":
    Installer().main()
