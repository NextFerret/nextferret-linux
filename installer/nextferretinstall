SIMULATE = "--simulate" in sys.argv

class NetUtils:
    @staticmethod
    def check_connection():
        if SIMULATE: return True
        try:
            socket.create_connection(("8.8.8.8", 53), timeout=3)
            return True
        except OSError:
            return False

    @staticmethod
    def get_svg_data(name, to_white=False):
        url = f"https://raw.githubusercontent.com/feathericons/feather/master/icons/{name}.svg"
        try:
            with urllib.request.urlopen(url, timeout=3) as response:
                data = response.read()
                if to_white:
                    data = data.replace(b'currentColor', b'#ffffff')
                return data
        except:
            return None

class Sys:
    @staticmethod
    def run(cmd, input_text=None, check=True):
        try:
            r = subprocess.run(cmd, shell=True, check=check, text=True, input=input_text, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
            return r.stdout.strip()
        except: return None

    @staticmethod
    def list_disks():
        if SIMULATE: return [{"name": "sda", "size": "500G", "model": "VBOX HARDDISK", "type": "disk"}]
        o = Sys.run("lsblk -d -n -o NAME,SIZE,MODEL,TYPE -J", check=False)
        if o:
            try: return [d for d in json.loads(o)['blockdevices'] if d['type'] == 'disk']
            except: return []
        return []

    @staticmethod
    def get_uuid(dev):
        if SIMULATE and "sda" in dev: return f"UUID-for-{dev}"
        return Sys.run(f"blkid -s UUID -o value {dev}")

    @staticmethod
    def list_locales():
        try:
            with open('/usr/share/i18n/SUPPORTED', 'r') as f:
                return sorted([line.split()[0] for line in f if 'UTF-8' in line])
        except:
            return ["en_US.UTF-8", "pt_BR.UTF-8", "es_ES.UTF-8", "fr_FR.UTF-8", "de_DE.UTF-8"]

    @staticmethod
    def list_keymaps():
        out = Sys.run("localectl list-x11-keymap-layouts", check=False)
        if out: return sorted([l for l in out.split('\n') if l.strip()])
        return sorted(["us", "br", "pt", "es", "fr", "de", "it", "gb"])

    @staticmethod
    def list_timezones():
        out = Sys.run("timedatectl list-timezones", check=False)
        if out: return [t for t in out.split('\n') if t.strip()]
        return ["UTC", "America/New_York", "America/Sao_Paulo", "Europe/London", "Europe/Paris", "Europe/Berlin", "Europe/Madrid", "Asia/Tokyo"]

    @staticmethod
    def is_vm():
        r = Sys.run("systemd-detect-virt", check=False)
        return r != "none" if r else False

    @staticmethod
    def is_on_battery():
        p = "/sys/class/power_supply"
        if not os.path.exists(p): return False
        for supply in os.listdir(p):
            if supply.startswith("BAT"):
                status_path = os.path.join(p, supply, "status")
                if os.path.exists(status_path):
                    with open(status_path, 'r') as f:
                        if f.read().strip() == "Discharging": return True
        return False

class InstallWorker(QThread):
    log_msg = pyqtSignal(str)
    finished = pyqtSignal(bool)

    def __init__(self, conf, locale):
        super().__init__()
        self.conf = conf
        self.sys_locale = locale
        self.mount = "/mnt/nextferret"
        self.mapper = "cryptferret"

    def run_cmd(self, cmd, input_text=None):
        self.log_msg.emit(f"== {cmd}")
        if SIMULATE:
            return True
        try:
            p = subprocess.Popen(cmd, shell=True, text=True, stdin=subprocess.PIPE, stdout=subprocess.PIPE, stderr=subprocess.STDOUT)
            if input_text:
                p.stdin.write(input_text + "\n")
                p.stdin.flush()
            for line in p.stdout:
                self.log_msg.emit(line.strip())
            p.wait()
            return p.returncode == 0
        except Exception as e:
            self.log_msg.emit(f"ERROR: {str(e)}")
            return False

    def run(self):
        if SIMULATE:
            sim_logs = [
                "==> wipefs -a /dev/sda",
                "/dev/sda: 8 bytes were erased at offset 0x00000200 (gpt): 45 46 49 20 50 41 52 54",
                "==> parted -s /dev/sda mklabel gpt",
                "==> parted -s /dev/sda mkpart ESP fat32 1MiB 513MiB",
                "==> parted -s /dev/sda set 1 esp on",
                "==> parted -s /dev/sda mkpart primary 513MiB 100%",
                "==> mkfs.vfat -F32 /dev/sda1",
                "mkfs.fat 4.2 (2021-01-31)",
                "==> mkfs.btrfs -f -L NextRoot /dev/sda2",
                "btrfs-progs v6.2",
                "See http://btrfs.wiki.kernel.org for more information.",
                "==> blkid -s UUID -o value /dev/sda2",
                "==> blkid -s UUID -o value /dev/sda1",
                "==> mount /dev/sda2 /mnt/tmp_install",
                "==> btrfs sub create /mnt/tmp_install/@",
                "Create subvolume '/mnt/tmp_install/@'",
                "==> btrfs sub create /mnt/tmp_install/@home",
                "Create subvolume '/mnt/tmp_install/@home'",
                "==> umount /mnt/tmp_install",
                "==> mount -o defaults,compress=zstd:1,noatime,subvol=@ /dev/sda2 /mnt/nextferret",
                "==> debootstrap --arch=amd64 trixie /mnt/nextferret http://deb.debian.org/debian",
                "I: Retrieving InRelease",
                "I: Checking Release signature",
                "I: Valid Release signature",
                "I: Retrieving Packages",
                "I: Validating Packages",
                "I: Resolving dependencies of required packages...",
                "I: Resolving dependencies of base packages...",
                "I: Checking component main on http://deb.debian.org/debian...",
                "I: Extracting base-files...",
                "I: Extracting apt...",
                "I: Extracting dpkg...",
                "I: Extracting systemd...",
                "I: Configuring base-files...",
                "I: Configuring apt...",
                "I: Base system installed successfully.",
                "==> wget -O /mnt/nextferret/tmp/nextferret-base.deb https://github.com/NextFerret/nextferretOS/releases/download/basenotiso/nextferret-base_999999.99999_all.deb",
                "Saving to: ‘/mnt/nextferret/tmp/nextferret-base.deb’",
                "200 OK",
                "==> mount --bind /dev /mnt/nextferret/dev",
                "==> chroot /mnt/nextferret /s.sh",
                "Adding user...",
                "Generating /etc/fstab...",
                "update-initramfs: Generating /boot/initrd.img-6.1.0-9-amd64",
                "Installing for x86_64-efi platform.",
                "Installation finished. No error reported.",
                "Generating grub configuration file ...",
                "Found linux image: /boot/vmlinuz-6.1.0-9-amd64",
                "Found initrd image: /boot/initrd.img-6.1.0-9-amd64",
                "done",
                "Installing grub-btrfs...",
                "Creating first system snapshot...",
                "Updating GRUB to include snapshots...",
                "==> umount -R /mnt/nextferret",
                "Installation complete."
            ]
            delay = 60.0 / len(sim_logs)
            for msg in sim_logs:
                self.log_msg.emit(msg)
                time.sleep(delay)
            self.finished.emit(True)
            return

        d = self.conf["disk"]
        self.log_msg.emit("Starting disk partitioning...")
        self.run_cmd(f"wipefs -a {d}")
        self.run_cmd(f"parted -s {d} mklabel gpt")
        self.run_cmd(f"parted -s {d} mkpart ESP fat32 1MiB 513MiB")
        self.run_cmd(f"parted -s {d} set 1 esp on")
        self.run_cmd(f"parted -s {d} mkpart primary 513MiB 100%")

        sep = "p" if "nvme" in d else ""
        p1, p2 = f"{d}{sep}1", f"{d}{sep}2"
        root_dev = p2

        if self.conf["luks"]:
            self.run_cmd(f"cryptsetup luksFormat --type luks2 {p2} -", self.conf["luks_pass"])
            self.run_cmd(f"cryptsetup open {p2} {self.mapper} -", self.conf["luks_pass"])
            root_dev = f"/dev/mapper/{self.mapper}"

        self.run_cmd(f"mkfs.vfat -F32 {p1}")
        self.run_cmd(f"mkfs.btrfs -f -L NextRoot {root_dev}")

        u_root = Sys.get_uuid(root_dev)
        u_efi = Sys.get_uuid(p1)
        if not u_root or not u_efi:
            self.log_msg.emit("ERROR: Could not get UUIDs for partitions. Cannot generate fstab.")
            self.finished.emit(False)
            return

        tmp = "/mnt/tmp_install"
        os.makedirs(tmp, exist_ok=True)
        self.run_cmd(f"mount {root_dev} {tmp}")
        self.run_cmd(f"btrfs sub create {tmp}/@")
        self.run_cmd(f"btrfs sub create {tmp}/@home")
        self.run_cmd(f"umount {tmp}")

        os.makedirs(self.mount, exist_ok=True)
        mnt_opts = "defaults,compress=zstd:1,noatime"
        self.run_cmd(f"mount -o {mnt_opts},subvol=@ {root_dev} {self.mount}")
        for p in ["home", "boot/efi"]: os.makedirs(f"{self.mount}/{p}", exist_ok=True)
        self.run_cmd(f"mount -o {mnt_opts},subvol=@home {root_dev} {self.mount}/home")
        self.run_cmd(f"mount {p1} {self.mount}/boot/efi")
        os.makedirs(f"{self.mount}/nf-tree/snapshots", exist_ok=True)

        if not self.run_cmd(f"debootstrap --arch=amd64 trixie {self.mount} http://deb.debian.org/debian"):
            self.finished.emit(False)
            return

        self.run_cmd(f"wget -O {self.mount}/tmp/nextferret-base.deb https://github.com/NextFerret/nextferretOS/releases/download/basenotiso/nextferret-base_999999.99999_all.deb")

        for m in ["/dev", "/dev/pts", "/proc", "/sys"]:
            self.run_cmd(f"mount --bind {m} {self.mount}{m}")
        shutil.copy("/etc/resolv.conf", f"{self.mount}/etc/resolv.conf")
        
        prefs_src = "/etc/apt/preferences.d/nextferret"
        if os.path.exists(prefs_src):
            os.makedirs(f"{self.mount}/etc/apt/preferences.d", exist_ok=True)
            shutil.copy2(prefs_src, f"{self.mount}/etc/apt/preferences.d/nextferret")

        motd_src = "/etc/motd"
        if os.path.exists(motd_src):
            shutil.copy2(motd_src, f"{self.mount}/etc/motd")

        for tool in ["/usr/bin/apt-nf-tree", "/usr/bin/nf-tree"]:
            if os.path.exists(tool):
                shutil.copy(tool, f"{self.mount}{tool}")
                self.run_cmd(f"chmod +x {self.mount}{tool}")

        for osf in ["/etc/os-release", "/usr/lib/os-release", "/etc/lsb-release", "/etc/issue", "/etc/issue.net", "/etc/debian_version"]:
            if os.path.lexists(osf):
                dst = f"{self.mount}{osf}"
                os.makedirs(os.path.dirname(dst), exist_ok=True)
                if os.path.lexists(dst):
                    os.remove(dst)
                if os.path.islink(osf):
                    os.symlink(os.readlink(osf), dst)
                else:
                    shutil.copy2(osf, dst)
        
        u_p2 = Sys.get_uuid(p2) if self.conf["luks"] else ""
        luks_sh = f"echo '{self.mapper} UUID={u_p2} none luks,discard,initramfs' > /etc/crypttab\napt-get install -y cryptsetup-initramfs\n" if self.conf["luks"] and u_p2 else ""
        de_sh = f"apt-get install -y -o Dpkg::Options::=--force-confdef -o Dpkg::Options::=--force-confold {self.conf['de_pkgs']}\n" if self.conf["de_pkgs"] else ""
        
        fstab_sh = f"""
cat << EOF > /etc/fstab
UUID={u_root} /               btrfs   defaults,compress=zstd:1,noatime,subvol=@ 0       0
UUID={u_root} /home           btrfs   defaults,compress=zstd:1,noatime,subvol=@home 0       0
UUID={u_efi}  /boot/efi       vfat    defaults        0       1
EOF
"""

        script = f"""#!/bin/bash
set -e
export DEBIAN_FRONTEND=noninteractive

echo "deb http://deb.debian.org/debian trixie main contrib non-free non-free-firmware" > /etc/apt/sources.list
echo "deb http://security.debian.org/debian-security trixie-security main contrib non-free" >> /etc/apt/sources.list

mkdir -p /etc/apt/preferences.d
cat << 'EOF' > /etc/apt/preferences.d/99-block-desktop-base
Package: desktop-base
Pin: release *
Pin-Priority: -2
EOF

for f in /etc/os-release /usr/lib/os-release /etc/lsb-release /etc/issue /etc/issue.net /etc/debian_version; do
    if [ -e "$f" ] || [ -L "$f" ]; then
        cp -a "$f" "$f.custom_bak"
        dpkg-divert --add --package nextferret-core --rename --divert "$f.distrib" "$f" || true
        mv "$f.custom_bak" "$f"
    fi
done

apt-get update

if [ -f /tmp/nextferret-base.deb ]; then
    dpkg -i /tmp/nextferret-base.deb || apt-get install -f -y
fi

mkdir -p /usr/share/apt-nf-tree
dpkg-divert --add --package nextferret-core --rename --divert /usr/share/apt-nf-tree/apt /usr/bin/apt
ln -sf /usr/bin/apt-nf-tree /usr/bin/apt

apt-get install -y --no-install-recommends python3 linux-image-amd64 sudo network-manager firmware-linux grub-efi-amd64-signed shim-signed locales keyboard-configuration console-setup ca-certificates plymouth plymouth-themes btrfs-progs grub-common gawk inotify-tools git make

sed -i "s/^# *{self.sys_locale}/{self.sys_locale}/" /etc/locale.gen || true
locale-gen || true
echo "LANG={self.sys_locale}" > /etc/default/locale

echo 'XKBLAYOUT="{self.conf["keymap"]}"' > /etc/default/keyboard
dpkg-reconfigure -f noninteractive keyboard-configuration

ln -sf /usr/share/zoneinfo/{self.conf["timezone"]} /etc/localtime

systemctl enable NetworkManager

{luks_sh}

userdel -r live 2>/dev/null || true
useradd -m -s /bin/bash -G sudo {self.conf['user']}
echo "{self.conf['user']}:{self.conf['pass']}" | chpasswd
echo "root:{self.conf['pass']}" | chpasswd
echo "{self.conf['hostname']}" > /etc/hostname
echo "127.0.0.1    localhost" > /etc/hosts
echo "::1          localhost ip6-localhost ip6-loopback" >> /etc/hosts
echo "127.0.1.1    {self.conf['hostname']}" >> /etc/hosts

{de_sh}

{fstab_sh}

if [ -d "/usr/share/plymouth/themes/blockchain" ]; then
    plymouth-set-default-theme blockchain || true
fi

update-initramfs -c -k all || update-initramfs -u
grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=NextFerretOS || true
update-grub || true

mkdir -p /tmp/grub-btrfs
git clone https://github.com/Antynea/grub-btrfs.git /tmp/grub-btrfs
cd /tmp/grub-btrfs
make install
cd /
rm -rf /tmp/grub-btrfs

if [ -x /usr/bin/nf-tree ]; then
    nf-tree create first-snapshot || true
fi

if [ -f /tmp/99nftree ]; then
    mv /tmp/99nftree /etc/apt/apt.conf.d/99nftree
fi

apt-get clean
rm /s.sh
exit 0
"""
        chroot_script_path = os.path.join(self.mount, "s.sh")
        with open(chroot_script_path, "w") as f: f.write(script)
        self.run_cmd(f"chmod +x {chroot_script_path}")
        self.run_cmd(f"chroot {self.mount} /s.sh")

        for m in ["/dev/pts", "/dev", "/proc", "/sys"]: self.run_cmd(f"umount {self.mount}{m}")
        try: self.run_cmd(f"umount -R {self.mount}")
        except: self.run_cmd(f"umount -l {self.mount}")

        if self.conf["luks"]: self.run_cmd(f"cryptsetup close {self.mapper}")

        self.finished.emit(True)

