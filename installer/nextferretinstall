    def validate_current_page(self):
        idx = self.stack.currentIndex()
        if idx == 1:
            self.sys_locale = self.c_locale.currentText()
            self.conf["timezone"] = self.i_tz.currentText()
        elif idx == 2:
            self.conf["keymap"] = self.c_key.currentText()
        elif idx == 3:
            self.conf["de_name"] = self.c_de.currentText()
            self.conf["de_pkgs"] = self.c_de.currentData()
        elif idx == 4:
            if self.c_disk.currentIndex() == -1:
                QMessageBox.warning(self, "Error", self.t("err_disk"))
                return False
            if self.chk_luks.isChecked() and not self.i_luks_p.text():
                QMessageBox.warning(self, "Error", self.t("err_pass"))
                return False
            self.conf["disk"] = self.c_disk.currentData()
            self.conf["luks"] = self.chk_luks.isChecked()
            self.conf["luks_pass"] = self.i_luks_p.text()
        elif idx == 5:
            user = self.i_user.text().strip()
            host = self.i_host.text().strip()
            if not user or not host:
                QMessageBox.warning(self, "Error", self.t("err_user"))
                return False
            p1, p2 = self.i_pass.text(), self.i_pass_c.text()
            if not p1 or p1 != p2:
                QMessageBox.warning(self, "Error", self.t("err_pass"))
                return False
            self.conf["user"] = user
            self.conf["hostname"] = host
            self.conf["pass"] = p1
        return True

    def go_next(self):
        idx = self.stack.currentIndex()
        
        if not self.validate_current_page():
            return
            
        if idx == 5:
            self.populate_summary()
            self.btn_next.setText(self.t("install"))
            self.btn_next.setIcon(self.get_nav_icon("install_btn"))
            self.btn_next.setProperty("primary", "true")
            self.apply_styles()
        elif idx == 6:
            self.start_install()
            return
        elif idx == 8:
            Sys.run("reboot")
            sys.exit(0)
            
        self.stack.setCurrentIndex(idx + 1)
        self.btn_back.setEnabled(True)
        self.update_sidebar()
        
        if self.stack.currentIndex() != 6 and self.stack.currentIndex() != 8:
            self.btn_next.setText(self.t("next"))
            self.btn_next.setIcon(self.get_nav_icon("next"))
            if self.stack.currentIndex() != 6:
                self.btn_next.setProperty("primary", "true")
                self.apply_styles()

    def go_back(self):
        idx = self.stack.currentIndex()
        if idx > 0:
            self.stack.setCurrentIndex(idx - 1)
            self.update_sidebar()
            self.btn_next.setText(self.t("next"))
            self.btn_next.setIcon(self.get_nav_icon("next"))
            self.btn_next.setProperty("primary", "true")
            self.apply_styles()
            if self.stack.currentIndex() == 0:
                self.btn_back.setEnabled(False)

    def start_install(self):
        self.stack.setCurrentIndex(7)
        self.update_sidebar()
        self.nav_container.hide()
        
        self.worker = InstallWorker(self.conf, self.sys_locale)
        self.worker.log_msg.connect(self.txt_log.append)
        self.worker.finished.connect(self.install_done)
        self.worker.start()

    def install_done(self, success):
        self.pbar.setRange(0, 1)
        self.pbar.setValue(1)
        if success:
            self.stack.setCurrentIndex(8)
            self.nav_container.show()
            self.btn_back.hide()
            self.btn_next.setText(self.t("quit"))
            self.btn_next.setIcon(self.get_nav_icon("check_btn"))
            self.btn_next.setProperty("primary", "true")
            self.apply_styles()
            self.update_sidebar()
        else:
            QMessageBox.critical(self, "Error", "Installation failed. Check logs.")
            self.btn_back.setEnabled(True)
            self.btn_next.hide()

            
    def apply_styles(self):
        self.setStyleSheet(STYLES)

if __name__ == "__main__":
    app = QApplication(sys.argv)
    app.setStyle("Fusion")
    
    if not NetUtils.check_connection():
        QMessageBox.critical(None, "Network Error", TEXT["en"]["net_err"])
        sys.exit(1)

    if os.geteuid() != 0 and not SIMULATE:
        QMessageBox.critical(None, "Error", "Must run as root.")
        sys.exit(1)
        
