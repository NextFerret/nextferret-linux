#!/bin/bash

if [ "$EUID" -ne 0 ]; then
  echo "Error: this script must be run as root."
  echo "Please run it with sudo or as root."
  exit 1
fi

set -e

echo "[+] Switching repositories from trixie to forky..."
sed -i 's/trixie/forky/g' /etc/apt/sources.list

echo "[+] Updating package lists..."
apt update

echo "[+] Upgrading packages..."
apt upgrade -y

echo "[+] Downloading os-release..."
wget -O /etc/os-release https://nextferret.github.io/etc/os-release

echo "[+] Removing old nextferret-updater..."
rm -f /usr/bin/nextferret-updater

echo "[+] Downloading new nextferret-updater..."
wget -O /usr/bin/nextferret-updater https://nextferret.github.io/nextferret-updater

echo "[+] Setting executable permissions..."
chmod +x /usr/bin/nextferret-updater

echo "[✓] Done."
